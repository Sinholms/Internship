# Strapi CMS - Dinkominfo Pekalongan
# Copy this file to .env.local and fill with real values

# === Next.js ENV contract ===
# Public safe - URL only, no secret
NEXT_PUBLIC_STRAPI_BASE_URL=https://cms.dinkominfo.pekalongankab.go.id
NEXT_PUBLIC_CDN_URL=https://cdn.pekalongankab.go.id
NEXT_PUBLIC_CDN=https://cdn.pekalongankab.go.id
# Server-only secret - never NEXT_PUBLIC_STRAPI_API_KEY
STRAPI_BASE_URL=https://cms.dinkominfo.pekalongankab.go.id
STRAPI_API_KEY=
# Optional form key
STRAPI_FORM_API_KEY=
# No NEXT_PUBLIC_STRAPI_API_KEY ever

# curl test:
# curl -H "Authorization: Bearer $STRAPI_API_KEY" "$NEXT_PUBLIC_STRAPI_BASE_URL/api/articles?pagination[pageSize]=1&populate=*" | python3 -m json.tool
