# Strapi CMS - Dinkominfo Pekalongan
# Copy this file to .env and fill with real values

# Base URL CMS tanpa trailing /api
VITE_STRAPI_BASE_URL= xxxxxxxx

# CDN base for /uploads
VITE_CDN_URL= xxxxxxxxx

# Read-only API token (Bearer) - dari Strapi Admin > Settings > API Tokens
# Contoh: f2fdbf50... panjang
VITE_STRAPI_API_KEY=

# Optional: Form API key if different
# VITE_STRAPI_FORM_API_KEY=
